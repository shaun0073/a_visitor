/**
 * 訪客暨櫃台管理系統 - 伺服器端 (靠左對齊優化版)
 * 結構定義：A:訪客證號, B:姓名, C:公司, D:受訪人, E:目的, F:電話, G:狀態, H:登記時間, I:簽退時間
 */
const SPREADSHEET_ID = "1U0pf9dKhtXUFA4rpGY_D7ZKqeNY4eg-cKpywyW_YcJ0";
const SHEET_NAME = "資料庫";

/**
 * 網頁進入點
 */
function doGet(e) {
  let page = e.parameter.page || 'index';
  try {
    const html = HtmlService.createTemplateFromFile(page);
    html.scriptUrl = ScriptApp.getService().getUrl();
    return html.evaluate()
      .setTitle(page === 'admin' ? '櫃檯管理系統' : '訪客登記系統')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
  } catch (err) {
    return HtmlService.createHtmlOutput("頁面不存在或載入錯誤。");
  }
}

/**
 * 【訪客登記端】儲存訪客登記資料
 * 移除系統 ID (J欄)，資料全部靠左對齊
 */
function saveVisitorRecord(formData) {
  const now = new Date();
  const timestamp = Utilities.formatDate(now, "GMT+8", "yyyyMMddHHmmss");
  const visitorId = "V-" + timestamp; 
  
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    
    const rawPhone = (formData.phone || "").trim();
    const formattedPhone = rawPhone ? "'" + rawPhone : "";

    // 只有 9 欄 (A-I)
    const row = [
      "'" + visitorId,                 // A: 訪客證號
      (formData.name || "").trim(),    // B: 姓名
      (formData.company || "").trim(), // C: 公司
      (formData.host || "").trim(),    // D: 受訪人
      (formData.purpose || "").trim(), // E: 目的
      formattedPhone,                  // F: 電話
      "待確認",                         // G: 狀態
      now,                             // H: 登記時間
      ""                               // I: 簽退時間
    ];
    
    sheet.appendRow(row);
    
    // 格式化與對齊處理
    const lastRow = sheet.getLastRow();
    const range = sheet.getRange(lastRow, 1, 1, 9);
    
    // 設置登記時間格式
    sheet.getRange(lastRow, 8).setNumberFormat("yyyy/MM/dd HH:mm:ss");
    
    // 全部靠左對齊
    range.setHorizontalAlignment("left");
    
    return { success: true, id: visitorId, message: "登記成功" };
  } catch (e) {
    return { success: false, error: "儲存失敗：" + e.message };
  }
}

/**
 * 【櫃檯管理端】抓取雲端資料
 */
function getCloudRecords() {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    
    const lastRow = sheet.getLastRow();
    if (lastRow <= 1) return []; 

    const maxFetch = 200; 
    const startRow = Math.max(2, lastRow - maxFetch + 1);
    const numRows = lastRow - startRow + 1;

    const range = sheet.getRange(startRow, 1, numRows, 9);
    const displayValues = range.getDisplayValues(); 

    const results = [];
    for (let i = displayValues.length - 1; i >= 0; i--) {
      if (!displayValues[i][0]) continue;

      results.push({
        visitorId: String(displayValues[i][0]).trim(),
        name: displayValues[i][1],
        company: displayValues[i][2],
        host: displayValues[i][3],
        purpose: displayValues[i][4],
        phone: displayValues[i][5],
        status: String(displayValues[i][6]).trim(),
        checkInTime: displayValues[i][7]
      });
    }
    return results;
  } catch (e) { 
    return []; 
  }
}

/**
 * 核心狀態更新函數
 * 資料更新時維持靠左對齊
 */
function updateStatus(visitorId, newStatus, isCheckout) {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    
    const lastRow = sheet.getLastRow();
    const cleanId = String(visitorId).trim();
    
    const rangeA = sheet.getRange(1, 1, lastRow, 1).getDisplayValues();
    let targetRowNum = -1;
    for (let i = rangeA.length - 1; i >= 1; i--) {
      if (String(rangeA[i][0]).trim() === cleanId) {
        targetRowNum = i + 1;
        break;
      }
    }

    if (targetRowNum !== -1) {
      // 1. 更新狀態
      sheet.getRange(targetRowNum, 7).setValue(newStatus);
      
      // 2. 設置該行資料靠左對齊 (A-I 欄)
      sheet.getRange(targetRowNum, 1, 1, 9).setHorizontalAlignment("left");
      
      // 3. 簽退時間更新
      if (isCheckout) {
        const now = new Date();
        const cell = sheet.getRange(targetRowNum, 9);
        cell.setValue(now);
        cell.setNumberFormat("yyyy/MM/dd HH:mm:ss");
      }
      
      SpreadsheetApp.flush(); 
      return { success: true };
    }
    return { success: false, error: "找不到證號" };
  } catch (e) { 
    return { success: false, error: e.toString() }; 
  }
}

function approveVisitor(visitorId) { return updateStatus(visitorId, "未簽退", false); }
function checkoutVisitor(visitorId) { return updateStatus(visitorId, "已簽退", true); }

/**
 * 訪客端狀態查詢
 */
function checkVisitorStatus(visitorId) {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    const lastRow = sheet.getLastRow();
    if (lastRow <= 1) return "查無資料";
    const startRow = Math.max(2, lastRow - 99);
    const data = sheet.getRange(startRow, 1, lastRow - startRow + 1, 7).getValues();
    const targetId = String(visitorId).trim();
    for (let i = data.length - 1; i >= 0; i--) {
      if (String(data[i][0]).trim() === targetId) return String(data[i][6]).trim();
    }
    return "查無資料";
  } catch (e) { return "系統錯誤"; }
}
